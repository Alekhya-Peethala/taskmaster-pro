{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://taskmaster-pro.com/schemas/task.json",
  "title": "Task",
  "description": "Schema for TaskMaster Pro Task entity. Defines structure, types, and validation rules for task objects.",
  "type": "object",
  "required": [
    "id",
    "title",
    "description",
    "dueDate",
    "priority",
    "status",
    "reminderSent",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": {
      "type": "integer",
      "description": "Unique task identifier (auto-generated by database)",
      "minimum": 1,
      "examples": [1, 42, 1001]
    },
    "title": {
      "type": "string",
      "description": "Short, descriptive task title",
      "minLength": 1,
      "maxLength": 255,
      "examples": [
        "Complete project proposal",
        "Review code changes",
        "Deploy to production"
      ]
    },
    "description": {
      "type": "string",
      "description": "Detailed explanation of the task",
      "minLength": 1,
      "maxLength": 65535,
      "examples": [
        "Finalize the Q2 project proposal document and submit for review",
        "Review PR #42 for backend refactoring and approve if tests pass",
        "Deploy version 2.1.0 to production environment using CI/CD pipeline"
      ]
    },
    "dueDate": {
      "type": "string",
      "description": "Task due date in YYYY-MM-DD format",
      "format": "date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "examples": [
        "2026-03-15",
        "2026-12-31",
        "2027-01-01"
      ]
    },
    "priority": {
      "type": "string",
      "description": "Task priority level indicating importance",
      "enum": ["Low", "Medium", "High"],
      "examples": ["Low", "Medium", "High"]
    },
    "status": {
      "type": "string",
      "description": "Current task status representing lifecycle state",
      "enum": ["Pending", "In Progress", "Completed"],
      "examples": ["Pending", "In Progress", "Completed"]
    },
    "reminderSent": {
      "type": "boolean",
      "description": "Flag indicating whether 24-hour reminder has been sent for this task",
      "default": false,
      "examples": [false, true]
    },
    "createdAt": {
      "type": "string",
      "description": "ISO 8601 timestamp when task was created",
      "format": "date-time",
      "examples": [
        "2026-03-10T14:30:00Z",
        "2026-03-12T09:15:00.123Z"
      ]
    },
    "updatedAt": {
      "type": "string",
      "description": "ISO 8601 timestamp of last task modification",
      "format": "date-time",
      "examples": [
        "2026-03-12T09:15:00Z",
        "2026-03-12T16:45:30.456Z"
      ]
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "id": 1,
      "title": "Complete project proposal",
      "description": "Finalize the Q2 project proposal document and submit for review",
      "dueDate": "2026-03-15",
      "priority": "High",
      "status": "In Progress",
      "reminderSent": false,
      "createdAt": "2026-03-10T14:30:00Z",
