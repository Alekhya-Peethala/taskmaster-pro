# TaskMaster Pro - Backend Environment Variables (Example)
# Generated with GitHub Copilot assistance
# Copy this file to .env and update with your actual values
# DO NOT commit .env file to version control

# ============================================================================
# Database Configuration
# ============================================================================
# Local Development (Docker Compose MySQL)
DATABASE_URL=mysql+mysqlconnector://taskuser:taskpass@localhost:3306/taskmaster

# Azure Production (Azure MySQL Flexible Server)
# DATABASE_URL=mysql+mysqlconnector://admin@taskmaster-mysql:PASSWORD@taskmaster-mysql.mysql.database.azure.com:3306/taskmaster?ssl_ca=/path/to/DigiCertGlobalRootCA.crt.pem

# ============================================================================
# Application Configuration
# ============================================================================
# Environment: development, staging, production
ENV=development

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# CORS Configuration
# ============================================================================
# Comma-separated list of allowed origins for CORS
# Local development:
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# Production (Azure Container Apps):
# ALLOWED_ORIGINS=https://taskmaster.azurecontainerapps.io

# ============================================================================
# API Configuration
# ============================================================================
# API port (default: 8000)
API_PORT=8000

# API host (default: 0.0.0.0 for all interfaces)
API_HOST=0.0.0.0

# ============================================================================
# Security (for future authentication implementation)
# ============================================================================
# SECRET_KEY=your-secret-key-here-change-in-production
# JWT_ALGORITHM=HS256
# JWT_EXPIRATION_MINUTES=30

# ============================================================================
# Azure Configuration (for production deployment)
# ============================================================================
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...
