# TaskMaster Pro - Backend .gitignore
# Generated with GitHub Copilot assistance
# Python-specific patterns

# ============================================================================
# Python
# ============================================================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ============================================================================
# Virtual Environments
# ============================================================================
venv/
env/
ENV/
env.bak/
venv.bak/
.venv/

# ============================================================================
# Testing & Coverage
# ============================================================================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/
.tox/

# ============================================================================
# Environment Variables & Secrets
# ============================================================================
.env
.env.*
!.env.example
*.key
*.pem

# ============================================================================
# Database
# ============================================================================
*.db
*.sqlite
*.sqlite3

